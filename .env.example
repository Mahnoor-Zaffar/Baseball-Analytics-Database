# Copy to .env and adjust as needed
POSTGRES_USER=baseball
POSTGRES_PASSWORD=baseball
POSTGRES_DB=baseball
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Postgres tuning (mirrored into postgresql.conf via env substitution if desired)
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=64MB
PG_EFFECTIVE_CACHE_SIZE=1GB

# Lahman release pinned for reproducibility
LAHMAN_VERSION=2023.1
LAHMAN_URL=https://github.com/chadwickbureau/baseballdatabank/archive/refs/tags/v2023.1.tar.gz

# Jupyter
JUPYTER_PORT=8888
JUPYTER_TOKEN=baseball

# FastAPI
API_PORT=8000
